# GeoCustody Container Deployment Environment
# Copy this to .env and fill in your values

# ===========================================
# Gateway Mode Configuration
# ===========================================
# Options:
#   mock    - Demo mode with simulated responses (orange button)
#   sandbox - Telefónica OpenGateway sandbox API (green button)
#   production - Telefónica production API (use with caution)
GATEWAY_MODE=mock

# Telefónica OpenGateway Credentials (required for sandbox/production)
# Get these from: https://opengateway.telefonica.com/
GATEWAY_CLIENT_ID=
GATEWAY_CLIENT_SECRET=

# ===========================================
# Application Security
# ===========================================
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string

# Set to true ONLY for local development — enables /docs, /redoc, /openapi.json
DEBUG=false

# ===========================================
# Cloudflare Tunnel (Optional)
# ===========================================
# Get token from Cloudflare Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=

# Your tunnel hostname for CORS configuration
TUNNEL_HOSTNAME=your-tunnel.example.com

# IMPORTANT: configure your Cloudflare tunnel origin as:
#   http://geocustody-frontend:80
# (not localhost — the cloudflared container reaches the frontend by container name)

# ===========================================
# Monitoring (Optional — monitoring Compose profile)
# ===========================================
# Enable with: podman-compose --profile monitoring up -d
# Or uncomment the line below to always start monitoring with the app:
# COMPOSE_PROFILES=monitoring

GRAFANA_ADMIN_USER=admin
# Generate a strong password: python3 -c "import secrets; print(secrets.token_hex(16))"
GRAFANA_ADMIN_PASSWORD=changeme

# Host ports for local monitoring UIs
# Defaults avoid common conflicts (e.g., Cockpit often uses 9090)
PROMETHEUS_PORT=19090
GRAFANA_PORT=13000
